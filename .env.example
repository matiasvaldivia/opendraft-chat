# --- LLM Provider ---
#   gemini -> google.genai SDK (direct, default)
#   openai -> OpenAI SDK against OPENAI_BASE_URL (LiteLLM / OpenRouter / Ollama / vLLM / ...)
AI_PROVIDER=openai

# --- OpenAI-compatible endpoint (LiteLLM / OpenAI / etc.) ---
# Get an OpenAI-compatible key from your LiteLLM admin or https://platform.openai.com
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://your-litellm.example.com/v1
OPENAI_MODEL=gemini-3.1-flash-lite
# OPENAI_MAX_OUTPUT_TOKENS=8192

# --- Gemini direct (alternative to OpenAI provider) ---
# GOOGLE_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3-flash-preview

# --- Optional alternative providers ---
# ANTHROPIC_API_KEY=your-claude-api-key

# --- Fallback Gemini keys for rate-limit resilience ---
# GOOGLE_API_KEY_FALLBACK=
# GOOGLE_API_KEY_FALLBACK_2=
# GOOGLE_API_KEY_FALLBACK_3=

# --- Citation API tuning (10x faster research) ---
# OpenAlex polite pool: any real email works.
OPENALEX_EMAIL=you@example.com

# Semantic Scholar API key — request free at https://www.semanticscholar.org/product/api
# Without a key: 1 req/sec (slow). With a key: 100 req/sec (fast).
SEMANTIC_SCHOLAR_API_KEY=
